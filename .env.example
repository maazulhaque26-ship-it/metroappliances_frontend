# ─── Frontend Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Full URL of the backend API (no trailing slash)
# Local dev:  http://localhost:5001/api
# Production: https://your-render-service.onrender.com/api
VITE_API_URL=

# Stripe publishable key (safe to expose in frontend — starts with pk_)
VITE_STRIPE_PUBLISHABLE_KEY=

# Razorpay key ID (safe to expose in frontend — starts with rzp_)
VITE_RAZORPAY_KEY_ID=
